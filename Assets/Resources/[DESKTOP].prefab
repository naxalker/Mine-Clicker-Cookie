  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u0435\u043C! \u0412\u044B
    \u043E\u0442\u043A\u0440\u044B\u043B\u0438 \u0432\u0441\u0435 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u044F!\n\n\u0412\u044B
    \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
    \u0438\u0433\u0440\u0430\u0442\u044C, \u0441\u043E\u0440\u0435\u0432\u043D\u0443\u044F\u0441\u044C
    \u0437\u0430 \u043F\u0435\u0440\u0432\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0435 \u043B\u0438\u0434\u0435\u0440\u043E\u0432,
    \u0438\u043B\u0438 \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441
    (\u0447\u0435\u0440\u0435\u0437 \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438)
    \u0438 \u043D\u0430\u0447\u0430\u0442\u044C \u0441\u043D\u0430\u0447\u0430\u043B\u0430!\n\n\u0410
    \u0435\u0449\u0435 \u043C\u044B \u0431\u0443\u0434\u0435\u043C \u043E\u0447\u0435\u043D\u044C
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u044B, \u0435\u0441\u043B\u0438
    \u0412\u044B \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u0435 \u043E\u0442\u0437\u044B\u0432!"
  m_isRightToLeft: 0
